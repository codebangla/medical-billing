@page "/invoices"

<PageTitle>Invoices - Medical Billing</PageTitle>

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Invoice Management</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill"></i>
                        <strong>Coming Soon!</strong> The Invoice management interface is being developed.
                    </div>
                    
                    <h5>Invoice Features:</h5>
                    <ul>
                        <li>Aggregate billing procedures into invoices</li>
                        <li>Generate invoice numbers</li>
                        <li>Calculate total amounts</li>
                        <li>Track payment status</li>
                        <li>Export to PDF</li>
                        <li>Send to insurance providers</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
